# App ID from GitHub App settings
APP_ID=
# Webhook secret you generated
WEBHOOK_SECRET=
# Path to the .pem file you downloaded
PRIVATE_KEY_PATH=./private-key.pem
# Comma-separated GitHub usernames to auto-approve (leave empty to approve all)
ALLOWED_AUTHORS=
# Set to "true" to enable AI code review via Amazon Bedrock (optional)
BEDROCK_ENABLED=
# Bedrock model ID (optional, defaults to Claude 3 Haiku)
BEDROCK_MODEL_ID=
