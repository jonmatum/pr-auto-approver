# App ID from GitHub App settings
APP_ID=
# Secrets Manager ARNs (set by Terraform, not manually)
PRIVATE_KEY_SECRET_ARN=
WEBHOOK_SECRET_SECRET_ARN=
# Comma-separated GitHub usernames to auto-approve (leave empty for all)
ALLOWED_AUTHORS=
# Set to "true" to enable AI code review via Amazon Bedrock
BEDROCK_ENABLED=
# Bedrock model ID (default: Claude 3.5 Haiku)
BEDROCK_MODEL_ID=
# GitHub PAT for approvals that count toward branch protection (optional)
APPROVAL_TOKEN_SECRET_ARN=
# For local dev only
PRIVATE_KEY_PATH=./private-key.pem
WEBHOOK_SECRET=
